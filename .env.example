# Required: Path to the target application
QA_APP_PATH=/path/to/your/app

# Required: Base URL for the running app
QA_BASE_URL=http://localhost:3000

# Required: GitHub repo for issue filing (owner/repo format)
QA_GITHUB_REPO=owner/repo

# Optional: GitHub PAT (defaults to gh CLI auth)
# QA_GITHUB_TOKEN=ghp_...

# Optional: Admin credentials for authenticated test flows
# QA_ADMIN_EMAIL=admin@example.com
# QA_ADMIN_PASSWORD=secret

# Optional: Database URL for direct DB assertions
# QA_DB_URL=mysql://user:pass@localhost:3306/dbname

# Required: Anthropic API key for AI agents
ANTHROPIC_API_KEY=sk-ant-...
